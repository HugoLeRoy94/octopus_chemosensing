Cell[CellGroupData[{
Cell["Optimize Interaction Energy of receptors", "Title",
 CellChangeTimes->{{3.972977680302297*^9, 
  3.9729776995981283`*^9}},ExpressionUUID->"f908a42f-2f75-4a2f-8129-\
524202ae5c9d"],

Cell["Starting from a physical model of channel activation:", "Text",
 CellChangeTimes->{{3.9729777423460913`*^9, 
  3.972977751797346*^9}},ExpressionUUID->"43686133-1ee0-4988-b4b8-\
444afb154959"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Energies", " ", "are", " ", "in", " ", "kBT", " ", 
    RowBox[{"units", "."}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"Ko", "[", "dEo_", "]"}], ":=", 
     RowBox[{"Exp", "[", 
      RowBox[{"-", "dEo"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"Kc", "[", "dEc_", "]"}], ":=", 
     RowBox[{"Exp", "[", 
      RowBox[{"-", "dEc"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"The", " ", "Activity", " ", "Function", " ", "y", 
     RowBox[{"(", 
      RowBox[{"c", ",", "params"}], ")"}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"MWC", "[", 
      RowBox[{"c_", ",", "dEo_", ",", "dEc_", ",", "eps_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "+", 
         RowBox[{"c", "/", 
          RowBox[{"Ko", "[", "dEo", "]"}]}]}], ")"}], "^", "5"}], "/", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", "+", 
           RowBox[{"c", "/", 
            RowBox[{"Ko", "[", "dEo", "]"}]}]}], ")"}], "^", "5"}], "+", 
        RowBox[{
         RowBox[{"Exp", "[", "eps", "]"}], "*", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"1", "+", 
            RowBox[{"c", "/", 
             RowBox[{"Kc", "[", "dEc", "]"}]}]}], ")"}], "^", "5"}]}]}], 
       ")"}]}]}], ";"}]}]}]], "Input",
 CellChangeTimes->{{3.9729777653470182`*^9, 3.972977765347053*^9}, 
   3.972982362301502*^9, 3.9729897158363333`*^9},
 CellLabel->"In[4]:=",ExpressionUUID->"bf179da0-aea8-4bcc-8f9f-2af2a775c02c"],

Cell["\<\
\[LineSeparator]We are looking for an optimal way that animals may have used \
to generate receptors. Here, we first propose that each of the receptors that \
compose the array have equal probability to be activated along the \
concentration. Thus, the question is to find the probability distribution of \
dEo, dEc, and eps that leads to a homogeneous activation probability.\
\>", "Text",
 CellChangeTimes->{{3.972977793254456*^9, 3.972977899242591*^9}, 
   3.972980557466371*^9},ExpressionUUID->"0ea9111a-efc8-47a0-971b-\
ce9b9840d3e9"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "2.", " ", "Define", " ", "the", " ", "Input", " ", "Distribution", " ", 
    "for", " ", "c"}], "*)"}], 
  RowBox[{"(*", 
   RowBox[{
   "Uniform", " ", "distribution", " ", "between", " ", "cMin", " ", "and", " ",
     "cMax"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"Pc", "[", 
      RowBox[{"c_", ",", "cMin_", ",", "cMax_"}], "]"}], ":=", 
     RowBox[{"Piecewise", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"1", "/", 
           RowBox[{"(", 
            RowBox[{"cMax", "-", "cMin"}], ")"}]}], ",", 
          RowBox[{"cMin", "<=", "c", "<=", "cMax"}]}], "}"}], "}"}], ",", 
       "0"}], "]"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "3.", " ", "Compute", " ", "the", " ", "Jacobian", " ", "term", " ", 
      "for", " ", "the", " ", "change", " ", "of", " ", "variable", " ", 
      "c"}], "->", "y"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"We", " ", "need", " ", 
     RowBox[{"dy", "/", "dc"}], " ", "to", " ", "transform", " ", "the", " ", 
     "density"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"dydc", "[", 
     RowBox[{"c_", ",", "dEo_", ",", "dEc_", ",", "eps_"}], "]"}], "=", 
    RowBox[{"D", "[", 
     RowBox[{
      RowBox[{"MWC", "[", 
       RowBox[{"c", ",", "dEo", ",", "dEc", ",", "eps"}], "]"}], ",", "c"}], 
     "]"}]}]}]}]], "Input",
 CellChangeTimes->{{3.972977900351158*^9, 3.972977903701535*^9}, 
   3.972989722860623*^9},
 CellLabel->"In[7]:=",ExpressionUUID->"ca15c2fb-775d-4a2a-8a57-922022de7fbf"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"solutionForC", "=", 
   RowBox[{"Reduce", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"a", "==", 
        RowBox[{"aFunc", "[", 
         RowBox[{"c", ",", "dEo", ",", "dEc", ",", "eps"}], "]"}]}], ",", 
       RowBox[{"c", ">", "0"}]}], "}"}], ",", "c", ",", "Reals"}], "]"}]}], 
  "\n"}]], "Input",
 CellChangeTimes->{{3.972990313058278*^9, 3.97299032599056*^9}},
 CellLabel->"In[11]:=",ExpressionUUID->"531a276b-a733-4cef-93d6-af80060739ff"],

