Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "5.", " ", "Define", " ", "the", " ", "Total", " ", "Probability", " ", 
    "P", 
    RowBox[{"(", "y", ")"}], " ", "by", " ", "integrating", " ", "over", " ", 
    "parameters"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Let", " ", "rhoEo"}], ",", "rhoEc", ",", 
    RowBox[{
    "rhoEps", " ", "be", " ", "the", " ", "unknown", " ", "distributions", " ",
      "you", " ", "want", " ", "to", " ", "find"}]}], "*)"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"PyTotal", "[", 
     RowBox[{"y_", ",", "rhoEo_", ",", "rhoEc_", ",", "rhoEps_"}], "]"}], ":=",
     "\[IndentingNewLine]", 
    RowBox[{"Integrate", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"PyConditional", "[", 
        RowBox[{"y", ",", "eo", ",", "ec", ",", "ep", ",", 
         RowBox[{"10", "^", 
          RowBox[{"-", "6"}]}], ",", 
         RowBox[{"10", "^", 
          RowBox[{"-", "1"}]}]}], "]"}], "*", 
       RowBox[{"rhoEo", "[", "eo", "]"}], "*", 
       RowBox[{"rhoEc", "[", "ec", "]"}], "*", 
       RowBox[{"rhoEps", "[", "ep", "]"}]}], ",", "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{"eo", ",", 
        RowBox[{"-", "Infinity"}], ",", "Infinity"}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{"ec", ",", 
        RowBox[{"-", "Infinity"}], ",", "Infinity"}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{"ep", ",", 
        RowBox[{"-", "Infinity"}], ",", "Infinity"}], "}"}]}], 
     "\[IndentingNewLine]", "]"}]}], ";"}]}]], "Input",
 CellChangeTimes->{{3.972980571626658*^9, 3.972980571626698*^9}, {
