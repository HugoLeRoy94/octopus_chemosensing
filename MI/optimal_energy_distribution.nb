    "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
      "===", "===", "===", "===", "===", "===", "===", "==="}], "="}], "*)"}],
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "Since", " ", "the", " ", "analytical", " ", "integral", " ", "above", " ",
      "is", " ", "likely", " ", "intractable"}], ","}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "here", " ", "is", " ", "how", " ", "you", " ", "generate", " ", "the", " ",
     "histogram", " ", "numerically", " ", "to", " ", "check", " ", 
    RowBox[{"uniformity", "."}]}], "*)"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"nSamples", "=", "10000"}], ",", 
      RowBox[{"cMin", "=", 
       RowBox[{"10", "^", 
        RowBox[{"-", "6"}]}]}], ",", 
      RowBox[{"cMax", "=", "1"}], ",", "samplesY"}], "}"}], ",", 
    "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{
     "Draw", " ", "random", " ", "parameters", " ", "from", " ", 
      "hypothetical", " ", "distributions"}], "*)"}], "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{
      RowBox[{"Example", ":", 
       RowBox[{"Eps", "~", 
        RowBox[{"Normal", "[", 
         RowBox[{"0", ",", "2"}], "]"}]}]}], ",", 
      RowBox[{"dEo", "~", 
       RowBox[{"Normal", "[", 
        RowBox[{
         RowBox[{"-", "5"}], ",", "2"}], "]"}]}], ",", 
      RowBox[{"dEc", "~", 
       RowBox[{"Normal", "[", 
        RowBox[{
         RowBox[{"-", "2"}], ",", "2"}], "]"}]}]}], "*)"}], 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"samplesY", "=", 
      RowBox[{"Table", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Module", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"c", ",", "eo", ",", "ec", ",", "ep", ",", "yVal"}], "}"}],
           ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"c", "=", 
            RowBox[{"RandomVariate", "[", 
             RowBox[{"UniformDistribution", "[", 
              RowBox[{"{", 
               RowBox[{"cMin", ",", "cMax"}], "}"}], "]"}], "]"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"eo", "=", 
            RowBox[{"RandomVariate", "[", 
             RowBox[{"NormalDistribution", "[", 
              RowBox[{
               RowBox[{"-", "5"}], ",", "2"}], "]"}], "]"}]}], ";", 
           RowBox[{"(*", 
            RowBox[{"Binding", " ", "Energy", " ", "Open"}], "*)"}], 
           "\[IndentingNewLine]", 
           RowBox[{"ec", "=", 
            RowBox[{"RandomVariate", "[", 
             RowBox[{"NormalDistribution", "[", 
              RowBox[{
               RowBox[{"-", "2"}], ",", "2"}], "]"}], "]"}]}], ";", 
           RowBox[{"(*", 
            RowBox[{"Binding", " ", "Energy", " ", "Closed"}], "*)"}], 
           "\[IndentingNewLine]", 
           RowBox[{"ep", "=", 
            RowBox[{"RandomVariate", "[", 
             RowBox[{"NormalDistribution", "[", 
              RowBox[{"2", ",", "2"}], "]"}], "]"}]}], ";", 
           RowBox[{"(*", 
            RowBox[{"Allosteric", " ", "Energy"}], "*)"}], 
           "\[IndentingNewLine]", "\[IndentingNewLine]", 
           RowBox[{"MWC", "[", 
            RowBox[{"c", ",", "eo", ",", "ec", ",", "ep"}], "]"}]}]}], "]"}], 
        ",", 
        RowBox[{"{", "nSamples", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]",
      "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
      "Plot", " ", "the", " ", "resulting", " ", "distribution", " ", "of", " ",
        "y"}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"If", " ", "this", " ", "Histogram", " ", "is", " ", "flat"}], 
       ",", 
       RowBox[{"your", " ", "parameter", " ", "distributions", " ", "are", " ", 
