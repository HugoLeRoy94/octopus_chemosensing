     RowBox[{"Histogram", "[", 
      RowBox[{"samplesY", ",", 
       RowBox[{"{", 
        RowBox[{"0", ",", "1", ",", "0.05"}], "}"}], ",", "\"\<PDF\>\"", ",", 
       
       RowBox[{"PlotLabel", "->", "\"\<Distribution P(y)\>\""}], ",", 
       RowBox[{"AxesLabel", "->", 
        RowBox[{"{", 
         RowBox[{"\"\<Activation y\>\"", ",", "\"\<Probability Density\>\""}],
          "}"}]}]}], "]"}]}]}], "]"}]}]], "Input",
