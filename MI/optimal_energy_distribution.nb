Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "4.", " ", "Express", " ", "the", " ", "Conditional", " ", "Density", " ", 
    "P", 
    RowBox[{"(", 
     RowBox[{"y", "|", "parameters"}], ")"}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"P", 
     RowBox[{"(", "y", ")"}]}], "=", 
    RowBox[{
     RowBox[{"P", 
      RowBox[{
       RowBox[{"(", "c", ")"}], "/"}]}], " ", "|", 
     RowBox[{"dy", "/", "dc"}], "|"}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "We", " ", "need", " ", "c", " ", "as", " ", "a", " ", "function", " ", 
     "of", " ", 
     RowBox[{"y", ".", "For"}], " ", "MWC"}], ",", 
    RowBox[{
     RowBox[{"inverting", " ", "y"}], "=", 
     RowBox[{"f", 
      RowBox[{"(", "c", ")"}], " ", "analytically", " ", "is", " ", 
      RowBox[{"messy", "."}]}]}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Instead", ",", 
    RowBox[{
    "we", " ", "define", " ", "the", " ", "density", " ", "parametrically", " ",
      "or", " ", "solve", " ", "numerically", " ", 
     RowBox[{"later", "."}]}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Analytically", ",", 
    RowBox[{
    "we", " ", "can", " ", "write", " ", "the", " ", "symbolic", " ", 
     RowBox[{"condition", ":"}]}]}], "*)"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"PyConditional", "[", 
     RowBox[{
     "y_", ",", "dEo_", ",", "dEc_", ",", "eps_", ",", "cMin_", ",", 
      "cMax_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"sol", ",", "cSol", ",", "jacobian"}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"Solve", " ", "for", " ", "c", " ", "given", " ", 
         RowBox[{"y", ".", "MWC"}], " ", "is", " ", "monotonic", " ", "in", " ",
          "c"}], ",", 
        RowBox[{
        "so", " ", "usually", " ", "1", " ", "solution", " ", "exists"}]}], 
       "*)"}], "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"sol", "=", 
        RowBox[{"Solve", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"y", "==", 
            RowBox[{"MWC", "[", 
             RowBox[{"cSol", ",", "dEo", ",", "dEc", ",", "eps"}], "]"}]}], "&&", 
           RowBox[{"cSol", ">", "0"}]}], ",", "cSol"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Length", "[", "sol", "]"}], "==", "0"}], ",", "0", ",", 
         RowBox[{
          RowBox[{"cSol", "=", 
           RowBox[{"cSol", "/.", " ", 
            RowBox[{"sol", "[", 
             RowBox[{"[", "1", "]"}], "]"}]}]}], ";", 
          RowBox[{"(*", 
           RowBox[{"Extract", " ", "the", " ", "concentration"}], "*)"}], 
          "\[IndentingNewLine]", "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
           "The", " ", "Change", " ", "of", " ", "Variables", " ", 
            "Formula"}], "*)"}], "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
            RowBox[{"P", 
             RowBox[{"(", "y", ")"}]}], "=", 
            RowBox[{
             RowBox[{
              RowBox[{"P", 
               RowBox[{"(", "c", ")"}], "*"}], " ", "|", 
              RowBox[{"dc", "/", "dy"}], "|"}], " ", "=", 
             RowBox[{
              RowBox[{"P", 
               RowBox[{
                RowBox[{"(", "c", ")"}], "/"}]}], " ", "|", 
              RowBox[{"dy", "/", "dc"}], "|"}]}]}], "*)"}], 
          "\[IndentingNewLine]", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Pc", "[", 
             RowBox[{"cSol", ",", "cMin", ",", "cMax"}], "]"}], "/", 
            RowBox[{"Abs", "[", 
             RowBox[{"dydc", "[", 
              RowBox[{"cSol", ",", "dEo", ",", "dEc", ",", "eps"}], "]"}], 
             "]"}]}], ")"}]}]}], "]"}]}]}], "]"}]}], ";"}]}]], "Input",
 CellChangeTimes->{{3.972980545718041*^9, 3.9729805457180853`*^9}, {
  3.97298063029253*^9, 3.972980693514596*^9}, {3.9729822090025167`*^9, 
