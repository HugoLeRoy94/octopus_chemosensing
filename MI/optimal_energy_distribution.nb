Cell[BoxData[
 RowBox[{"Reduce", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"a", "\[Equal]", 
      RowBox[{"aFunc", "[", 
       RowBox[{"c", ",", "dEo", ",", "dEc", ",", "eps"}], "]"}]}], ",", 
