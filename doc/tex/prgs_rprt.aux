\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Statistics of the optimization of 5 homo-pentamers over a single family of ligand. Left hand side, the evolution of the mutual information, the first data point is in a different scale and is separated by 100 optimizattion steps with the second point. Right hand side, we see that the optimization correspond to an increase of the average inter distance between receptors defined as $d = \DOTSB \sum@ \slimits@ _{u,u'} \|\textbf  {v}_u - \textbf  {v}_{u'}\|$}}{3}{figure.1}\protected@file@percent }
\newlabel{fig:entropy_distance}{{1}{3}{Statistics of the optimization of 5 homo-pentamers over a single family of ligand. Left hand side, the evolution of the mutual information, the first data point is in a different scale and is separated by 100 optimizattion steps with the second point. Right hand side, we see that the optimization correspond to an increase of the average inter distance between receptors defined as $d = \sum _{u,u'} \|\textbf {v}_u - \textbf {v}_{u'}\|$}{figure.1}{}}
\@writefile{toc}{\contentsline {section}{\numberline {V}Results}{3}{section*.12}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {A}Single familly optimization}{3}{section*.13}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Chemical, latent space representation of the optimization of 5 homo-pentamers. The gradient of color is proportional to the probability of drawing a ligand from that family. The center of the distribution is the blue dot. The closer a receptor is to a ligand, the larger their affinity. Notice that the UMAP representation distord the geometry, and does not conserve the distances.}}{4}{figure.2}\protected@file@percent }
\newlabel{fig:1fam_latent}{{2}{4}{Chemical, latent space representation of the optimization of 5 homo-pentamers. The gradient of color is proportional to the probability of drawing a ligand from that family. The center of the distribution is the blue dot. The closer a receptor is to a ligand, the larger their affinity. Notice that the UMAP representation distord the geometry, and does not conserve the distances}{figure.2}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {B}Highly complex environment}{4}{section*.14}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Mutual information of an array of receptors over a single family of ligand. The blue line represents 5 independant homo-pentamers, whereas the other line use less genes to encode the same number of ligands. To generate more receptors, we select a single random combination of hetero-pentamers. We illustrate the specific hetero-pentamer combination used around the yellow curve.}}{4}{figure.3}\protected@file@percent }
\newlabel{fig:MI_sensors_1fam}{{3}{4}{Mutual information of an array of receptors over a single family of ligand. The blue line represents 5 independant homo-pentamers, whereas the other line use less genes to encode the same number of ligands. To generate more receptors, we select a single random combination of hetero-pentamers. We illustrate the specific hetero-pentamer combination used around the yellow curve}{figure.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Chemical latent space representation of an optimized array of 5 homo-pentamers across 10 distinct ligand families. The environmental probability distributions of the different families are kept close enough to slightly overlap, avoiding isolated vacuums. As in the single-family case, this 2D projection distorts the true 10-dimensional geometric distances.}}{4}{figure.4}\protected@file@percent }
\newlabel{fig:10_fam_latent}{{4}{4}{Chemical latent space representation of an optimized array of 5 homo-pentamers across 10 distinct ligand families. The environmental probability distributions of the different families are kept close enough to slightly overlap, avoiding isolated vacuums. As in the single-family case, this 2D projection distorts the true 10-dimensional geometric distances}{figure.4}{}}
